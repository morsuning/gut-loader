{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "默认应用权限能力配置",
    "windows": [
        "main"
    ],
    "permissions": [
        "core:default",
        "core:window:default",
        "core:window:allow-start-dragging",
        "core:window:allow-minimize",
        "core:window:allow-toggle-maximize",
        "core:window:allow-close",
        "core:webview:default",
        "core:event:default",
        "core:app:default",
        "dialog:default",
        "shell:default",
        "fs:default",
        "fs:allow-read-text-file",
        "fs:allow-read-dir",
        "fs:allow-exists"
    ]
}